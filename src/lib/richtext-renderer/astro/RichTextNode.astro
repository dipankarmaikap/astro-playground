---
/**
 * RichTextNode.astro — renders a single ProseMirror node recursively.
 *
 * - Text nodes render as raw text.
 * - Nodes with marks are wrapped via <MarkWrapper>.
 * - Nodes with a CustomNode component use that component (with children as slot).
 * - Blok nodes use blokComponents to render Storyblok components.
 * - Fallback nodes use <RenderDOMSpec> which applies the Tiptap toDOM() spec.
 */
import type { Node as PMNode } from "@tiptap/pm/model";
import type { CoreRenderer } from "../core/renderer";
import type { BlokBody } from "../core/types";
import type { ComponentMap, BlokComponentMap } from "./types";
import MarkWrapper from "./MarkWrapper.astro";
import RenderDOMSpec from "./RenderDOMSpec.astro";
import BlokRenderer from "./BlokRenderer.astro";

export interface Props {
  node: PMNode;
  renderer: CoreRenderer;
  components: ComponentMap;
  blokComponents?: BlokComponentMap;
  index: number;
  isMarkWrapped?: boolean;
}

const {
  node,
  renderer,
  components,
  blokComponents = {},
  index,
  isMarkWrapped = false,
} = Astro.props;

// 1. Get default DOM Output Spec and exact Marks
const domSpec = renderer.getNodeDOMSpec(node);
const markDefs = renderer.getMarksForNode(node);

// 2. Resolve the Custom Node Component
const CustomNode = components[node.type.name as keyof typeof components] as any;

// 3. Check if this is a blok node
const isBlokNode = node.type.name === "blok";
const blokBody = isBlokNode ? (node.attrs.body || []) as BlokBody[] : [];

// 4. Resolve attributes - now always include parsedDOM for custom components
const nodeProps = CustomNode
  ? { node, attrs: node.attrs, parsedDOM: domSpec }
  : domSpec
    ? { ...domSpec.attrs }
    : {};

// 5. Collect children
const childrenNodes: PMNode[] = [];
node.forEach((childNode) => {
  childrenNodes.push(childNode);
});
---

{/* Wrap with Marks first unless already wrapped */}
{
  !isMarkWrapped && markDefs.length > 0 ? (
    <MarkWrapper
      node={node}
      renderer={renderer}
      components={components}
      blokComponents={blokComponents}
      marks={markDefs}
      index={index}
    />
  ) : (
    <>
      {node.isText ? (
        <>{node.text}</>
      ) : isBlokNode && Object.keys(blokComponents).length > 0 ? (
        <BlokRenderer bloks={blokBody} blokComponents={blokComponents} />
      ) : CustomNode ? (
        <CustomNode {...nodeProps}>
          {childrenNodes.length > 0 && childrenNodes.map((childNode, childIndex) => (
            <Astro.self
              node={childNode}
              renderer={renderer}
              components={components}
              blokComponents={blokComponents}
              index={childIndex}
            />
          ))}
        </CustomNode>
      ) : domSpec ? (
        <RenderDOMSpec spec={domSpec}>
          {childrenNodes.length > 0 && childrenNodes.map((childNode, childIndex) => (
            <Astro.self
              node={childNode}
              renderer={renderer}
              components={components}
              blokComponents={blokComponents}
              index={childIndex}
            />
          ))}
        </RenderDOMSpec>
      ) : (
        childrenNodes.map((childNode, childIndex) => (
          <Astro.self
            node={childNode}
            renderer={renderer}
            components={components}
            blokComponents={blokComponents}
            index={childIndex}
          />
        ))
      )}
    </>
  )
}

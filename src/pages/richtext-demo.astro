---
import AstroRichTextRenderer from "../lib/richtext-renderer/astro/RichTextRenderer.astro";
import ReactDemo from "../components/ReactRichTextDemo.tsx";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sampleDoc } from "../data/sampleDoc";
import CustomAstroHeading from "../components/CustomAstroHeading.astro";

// We pass components dynamically!
const astroComponents = {
  heading: CustomAstroHeading,
};
---

<BaseLayout>
  <div class="bg-gray-50 min-h-screen p-8 text-gray-900">
    <div class="max-w-4xl mx-auto space-y-12">
      {/* Astro Adapter Output */}
      <section>
        <h2 class="text-2xl font-bold mb-4 text-orange-600">
          Astro Native Renderer Output
        </h2>

        {
          /* We use tailwind typography class `prose` to let tailwind style standard elements */
        }
        <div
          class="p-6 bg-white rounded-lg shadow-md border border-gray-200 prose prose-orange max-w-none"
        >
          <AstroRichTextRenderer doc={sampleDoc} components={astroComponents} />
        </div>
      </section>

      {/* React Adapter Output */}
      <section>
        <h2 class="text-2xl font-bold mb-4 text-blue-600">
          React Renderer Output (with Custom Components)
        </h2>
        {/* The React demo mounts client-side and renders custom overrides */}
        <ReactDemo client:load />
      </section>
    </div>
  </div>
</BaseLayout>

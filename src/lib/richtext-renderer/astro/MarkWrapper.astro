---
import type { Node as PMNode } from "@tiptap/pm/model";
import type { CoreRenderer } from "../core/renderer";
import type { FrameworkComponentMap, MarkMapItem } from "../core/types";
import NodeIter from "./NodeIter.astro";

export interface Props {
  node: PMNode;
  renderer: CoreRenderer;
  components: FrameworkComponentMap<any>;
  marks: MarkMapItem[];
  index: number;
}

const { node, renderer, components, marks, index } = Astro.props;

if (marks.length === 0) {
  // If no more marks to wrap, delegate back to NodeIter to render the actual node content
  // We use a special flag `isMarkWrapped=true` so NodeIter doesn't re-wrap it infinitely
}

const currentMark = marks[0];
const remainingMarks = marks.slice(1);

const CustomMark = components[currentMark.type as keyof typeof components];
// In Astro, a lowercase string (e.g., 'strong') is interpreted as HTML, but uppercase is a component.
// We must use a dynamic tag syntax for standard HTML elements.
const Tag = CustomMark
  ? CustomMark
  : currentMark.spec
    ? currentMark.spec.tag
    : null;

const markProps = CustomMark
  ? {
      mark: currentMark.pmMark,
      attrs: currentMark.attrs,
      parsedDOM: currentMark.spec,
    }
  : currentMark.spec
    ? { ...currentMark.spec.attrs }
    : {};
---

{
  Tag ? (
    <Tag {...markProps}>
      {remainingMarks.length > 0 ? (
        <Astro.self
          node={node}
          renderer={renderer}
          components={components}
          marks={remainingMarks}
          index={index}
        />
      ) : (
        <NodeIter
          node={node}
          renderer={renderer}
          components={components}
          index={index}
          isMarkWrapped={true}
        />
      )}
    </Tag>
  ) : (
    <>
      {/* Should not happen, but fallback to unwrapping */}
      {remainingMarks.length > 0 ? (
        <Astro.self
          node={node}
          renderer={renderer}
          components={components}
          marks={remainingMarks}
          index={index}
        />
      ) : (
        <NodeIter
          node={node}
          renderer={renderer}
          components={components}
          index={index}
          isMarkWrapped={true}
        />
      )}
    </>
  )
}

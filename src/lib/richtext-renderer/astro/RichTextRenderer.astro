---
import type { AnyExtension } from "@tiptap/core";
import { CoreRenderer } from "../core/renderer";
import type {
  TiptapJSON,
  FrameworkComponentMap,
  NodeComponentProps,
  MarkComponentProps,
} from "../core/types";
// Re-export type helpers for users building Astro custom components!
export type RichTextNodeProps<T extends string = string> =
  NodeComponentProps<T>;
export type RichTextMarkProps<T extends string = string> =
  MarkComponentProps<T>;
import NodeIter from "./NodeIter.astro";

export interface Props {
  doc: TiptapJSON;
  extensions?: AnyExtension[];
  components?: FrameworkComponentMap<any>;
}

const { doc, extensions, components = {} } = Astro.props;

// Initialize the core renderer
const renderer = new CoreRenderer(extensions);
const pmDoc = renderer.parseDocument(doc);

// Extract the top level nodes to pass to our iterator
const nodes: import("@tiptap/pm/model").Node[] = [];
pmDoc.forEach((childNode) => {
  nodes.push(childNode);
});
---

{
  nodes.map((node, index) => (
    <NodeIter
      node={node}
      renderer={renderer}
      components={components}
      index={index}
    />
  ))
}

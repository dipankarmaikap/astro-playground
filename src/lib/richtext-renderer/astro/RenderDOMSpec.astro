---
import type { ParsedDOMSpec } from "../core/types";
import { VOID_ELEMENTS } from "../core/renderer";
import { normalizeDOMAttrs } from "../core/attrs";

export interface Props {
  spec: ParsedDOMSpec;
}

const { spec } = Astro.props;

// Normalize attributes using shared utility (important for style unification!)
const normalizedAttrs = normalizeDOMAttrs(spec.attrs);

// Is it a void element?
const isVoid = VOID_ELEMENTS.has(spec.tag.toLowerCase());

// Astro allows dynamic tags via Capitalized variable names
const Tag = spec.tag as any;
---

{
  isVoid ? (
    <Tag {...normalizedAttrs} />
  ) : (
    <Tag {...normalizedAttrs}>
      {spec.children.map((child) => {
        if (typeof child === "string") return child;
        if (typeof child === "object" && "hole" in child && child.hole) {
          // Inject Tiptap nested nodes into the "hole"
          return <slot />;
        }
        return (
          <Astro.self spec={child as ParsedDOMSpec}>
            {/* Pass the slotted children down recursively so they eventually land in the hole */}
            <slot />
          </Astro.self>
        );
      })}
    </Tag>
  )
}

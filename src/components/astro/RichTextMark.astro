---
import type { PMMark } from '@storyblok/richtext/static';
import { resolveComponent, resolveTag, processAttrs } from '@storyblok/richtext/static';
import { type SBAstroComponentMap, type AstroComponent, isValidAstroComponent } from './utils';

interface Props {
  mark: PMMark;
  components?: SBAstroComponentMap;
}

const { mark, components } = Astro.props;

// Type-safe component resolution with proper type guard
const resolvedComponent = resolveComponent(mark.type, components);
const MarkComponent: AstroComponent | null = isValidAstroComponent(resolvedComponent) ? resolvedComponent : null;

// Type-safe tag resolution with proper type guard
const Tag = resolveTag(mark);

const attrs = processAttrs(mark.type, mark.attrs);
---

{
  MarkComponent ? (
    <MarkComponent {...mark} components={components}>
      <slot />
    </MarkComponent>
  ) : (
    Tag && (
      <Tag {...attrs}>
        <slot />
      </Tag>
    )
  )
}

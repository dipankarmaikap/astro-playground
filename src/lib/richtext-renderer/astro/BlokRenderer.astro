---
/**
 * BlokRenderer.astro — renders Storyblok components embedded in rich text.
 *
 * Maps blok body items to their corresponding Astro components.
 */
import type { BlokBody } from "../core/types";
import type { BlokComponentMap } from "./types";

export interface Props {
  /** Array of blok body items to render */
  bloks: BlokBody[];
  /** Map of component names to Astro components */
  blokComponents: BlokComponentMap;
}

const { bloks, blokComponents } = Astro.props;
---

{bloks.map((blok) => {
  const Component = blokComponents[blok.component];
  return Component ? (
    <Component blok={blok} />
  ) : (
    <div data-unknown-blok={blok.component}>
      Unknown component: {blok.component}
    </div>
  );
})}

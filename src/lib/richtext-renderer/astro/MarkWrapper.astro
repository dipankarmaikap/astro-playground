---
/**
 * MarkWrapper.astro — recursively wraps the node with its ProseMirror marks.
 *
 * Takes the first mark, wraps content with it (using a CustomMark component
 * or the default DOMSpec tag), then recurses for remaining marks.
 */
import type { Node as PMNode } from "@tiptap/pm/model";
import type { CoreRenderer } from "../core/renderer";
import type { MarkMapItem } from "../core/types";
import type { ComponentMap, BlokComponentMap } from "./types";
import RichTextNode from "./RichTextNode.astro";
import RenderDOMSpec from "./RenderDOMSpec.astro";

export interface Props {
  node: PMNode;
  renderer: CoreRenderer;
  components: ComponentMap;
  blokComponents?: BlokComponentMap;
  marks: MarkMapItem[];
  index: number;
}

const { node, renderer, components, blokComponents = {}, marks, index } = Astro.props;

const currentMark = marks[0];
const remainingMarks = marks.slice(1);

const CustomMark = components[currentMark.type as keyof typeof components] as any;

// Props passed to custom mark components, including parsedDOM
const markProps = CustomMark
  ? {
      mark: currentMark.pmMark,
      attrs: currentMark.attrs,
      parsedDOM: currentMark.spec,
    }
  : currentMark.spec
    ? { ...currentMark.spec.attrs }
    : {};
---

{
  CustomMark ? (
    <CustomMark {...markProps}>
      {remainingMarks.length > 0 ? (
        <Astro.self
          node={node}
          renderer={renderer}
          components={components}
          blokComponents={blokComponents}
          marks={remainingMarks}
          index={index}
        />
      ) : (
        <RichTextNode
          node={node}
          renderer={renderer}
          components={components}
          blokComponents={blokComponents}
          index={index}
          isMarkWrapped={true}
        />
      )}
    </CustomMark>
  ) : currentMark.spec ? (
    <RenderDOMSpec spec={currentMark.spec}>
      {remainingMarks.length > 0 ? (
        <Astro.self
          node={node}
          renderer={renderer}
          components={components}
          blokComponents={blokComponents}
          marks={remainingMarks}
          index={index}
        />
      ) : (
        <RichTextNode
          node={node}
          renderer={renderer}
          components={components}
          blokComponents={blokComponents}
          index={index}
          isMarkWrapped={true}
        />
      )}
    </RenderDOMSpec>
  ) : (
    <>
      {/* Fallback: no spec for this mark, pass through */}
      {remainingMarks.length > 0 ? (
        <Astro.self
          node={node}
          renderer={renderer}
          components={components}
          blokComponents={blokComponents}
          marks={remainingMarks}
          index={index}
        />
      ) : (
        <RichTextNode
          node={node}
          renderer={renderer}
          components={components}
          blokComponents={blokComponents}
          index={index}
          isMarkWrapped={true}
        />
      )}
    </>
  )
}

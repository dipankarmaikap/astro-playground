---
import type { PMNode } from '@storyblok/richtext/static';
import {
  isSelfClosing,
  resolveComponent,
  resolveTag,
  getStaticChildren,
  processAttrs,
  styleToString,
} from '@storyblok/richtext/static';
import RichTextText from './RichTextText.astro';
import RichTextStatic from './RichTextStatic.astro';
import { type SBAstroComponentMap, isValidAstroComponent } from './utils';

interface Props {
  node: PMNode;
  components?: SBAstroComponentMap;
}

const { node, components = {} } = Astro.props;

// Type-safe component resolution with proper type guard
const resolvedComponent = node.type !== 'text' ? resolveComponent(node.type, components) : null;
const NodeComponent = isValidAstroComponent(resolvedComponent) ? resolvedComponent : null;

// Type-safe tag resolution with proper type guard
const Tag = resolveTag(node);
const selfClosing = Tag ? isSelfClosing(Tag) : false;
const staticChildren = getStaticChildren(node);
const attrs = node.type !== 'text' ? processAttrs(node.type, node.attrs) : {};
const styleString = attrs.style && styleToString(attrs.style);
const htmlAttrs = {
  ...attrs,
  ...(styleString && { style: styleString }),
};
---

{
  node.type === 'text' ? (
    <RichTextText node={node} components={components} />
  ) : NodeComponent ? (
    <NodeComponent {...node} components={components} />
  ) : Tag ? (
    selfClosing ? (
      <Tag {...htmlAttrs} />
    ) : (
      <Tag {...(staticChildren ? {} : htmlAttrs)}>
        {staticChildren ? (
          <RichTextStatic attrs={htmlAttrs} staticChildren={staticChildren}>
            {node.content?.map((childNode) => (
              <Astro.self node={childNode} components={components} />
            ))}
          </RichTextStatic>
        ) : (
          node.content?.map((childNode) => <Astro.self node={childNode} components={components} />)
        )}
      </Tag>
    )
  ) : null
}

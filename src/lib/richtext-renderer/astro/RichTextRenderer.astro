---
/**
 * RichTextRenderer.astro — entry point for the Astro rich-text renderer.
 *
 * Accepts a Tiptap/ProseMirror JSON document and an optional component map,
 * then renders each top-level node via RichTextNode.
 *
 * @example
 * ```astro
 * ---
 * import RichTextRenderer from '@storyblok/richtext-renderer/astro';
 * import CustomHeading from './CustomHeading.astro';
 *
 * const { richTextData } = Astro.props;
 * ---
 *
 * <RichTextRenderer
 *   doc={richTextData}
 *   components={{ heading: CustomHeading }}
 * />
 * ```
 *
 * @example With blok components
 * ```astro
 * ---
 * import RichTextRenderer from '@storyblok/richtext-renderer/astro';
 * import Feature from './Feature.astro';
 * import CTA from './CTA.astro';
 *
 * const { richTextData } = Astro.props;
 * ---
 *
 * <RichTextRenderer
 *   doc={richTextData}
 *   blokComponents={{
 *     feature: Feature,
 *     cta: CTA,
 *   }}
 * />
 * ```
 */
import { CoreRenderer } from '../core/renderer';
import type { ComponentMap, BlokComponentMap } from './types';
import type { Node as PMNode } from '@tiptap/pm/model';

import RichTextNode from './RichTextNode.astro';
import type { JSONContent } from '../core/types';

export interface Props {
  /** The Tiptap/ProseMirror JSON document to render */
  doc: JSONContent;
  /** Custom components to use for specific node/mark types */
  components?: ComponentMap;
  /**
   * Component map for Storyblok blok nodes.
   * Maps component names to Astro components.
   */
  blokComponents?: BlokComponentMap;
}

const { doc, components = {}, blokComponents = {} } = Astro.props;

// Initialize the core renderer
const renderer = new CoreRenderer();
const pmDoc = renderer.parseDocument(doc);

// Extract the top level nodes to pass to our iterator
const nodes: PMNode[] = [];
pmDoc.forEach((childNode) => {
  nodes.push(childNode);
});
---

{
  nodes.map((node, index) => (
    <RichTextNode
      node={node}
      renderer={renderer}
      components={components}
      blokComponents={blokComponents}
      index={index}
    />
  ))
}
